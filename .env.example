# Port the HTTP server listens on
CLI2API_PORT=8080

# Comma-separated inbound API keys. Empty = unauthenticated (local-only).
# CLI2API_API_KEYS=sk-local-1,sk-local-2

# Async job store DSN. Empty = in-memory (jobs lost on restart).
#   file:/var/lib/cli2api/jobs.db   local libsql (pure-Go, no CGO)
#   libsql://host?authToken=...     Turso / sqld remote
#   /var/lib/cli2api/jobs.db        bare path == file: prefix
# CLI2API_JOBSTORE_DSN=file:/var/lib/cli2api/jobs.db

# How long async job rows live before the reaper deletes them.
# 0 = jobs never expire (reaper sweeps are skipped). Default 168h (7 days).
# Note: terminal jobs (completed/failed) are reaped at expires_at.
# In-flight jobs (queued/in_progress) are kept until expires_at + retention*HARD_CAP_MULT
# so a client that's still polling won't see its task disappear mid-flight.
# CLI2API_JOB_RETENTION=168h

# How often the reaper sweeps. 0 = reaper disabled. Default 1h.
# CLI2API_REAPER_INTERVAL=1h

# Hard-cap multiplier for in-flight (queued/in_progress) jobs.
# A job is force-deleted past expires_at + retention*MULT regardless of status,
# so a client that abandoned the polling loop doesn't grow the store forever.
# Default 3.0. Range: 1.0–1000.0. Inf/NaN/<1/>1000 are silently rejected.
# CLI2API_JOB_HARD_CAP_MULT=3.0

# Upstream mulerun token. If unset, the server falls back to:
#   ~/.config/mulerun/oauth_cache.json  (mulerun-cli >= 0.1.0)
#   ~/.mulerun/{auth,credentials,token}.json  (older versions)
# MULERUN_TOKEN=mr_xxxxxxxxxxxxxxx

# Override the upstream base URL (rarely needed).
# MULERUN_API_BASE_URL=https://api.mulerun.com

# How long the synchronous /v1/images/generations call will wait
# CLI2API_IMAGE_TIMEOUT=5m

# Internal polling cadence for upstream jobs (initial / max)
# CLI2API_POLL_INTERVAL=2s
# CLI2API_POLL_MAX_INTERVAL=10s

# Log level: debug | info | warn | error
# CLI2API_LOG_LEVEL=info
